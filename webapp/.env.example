# Salin menjadi .env.local lalu isi dari dashboard Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# HANYA untuk script import (scripts/import-csv.mjs), jangan dipakai di frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# API key Google Gemini (pakai key yang sama dengan proyek Dagang Cerdas)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
